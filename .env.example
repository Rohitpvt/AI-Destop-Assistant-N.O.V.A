# NOVA Environment Configuration

# Assistant Identity
NOVA_ASSISTANT_NAME=NOVA

# Logging Settings
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
NOVA_LOG_LEVEL=INFO

# Feature Directories (Leave blank for defaults)
# Default is project root or standard system folders
NOVA_MUSIC_DIR=
NOVA_NOTES_DIR=
NOVA_SCREENSHOT_DIR=

# Future AI Provider Settings - placeholders only
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
