# NOVA Environment Configuration

# Assistant Identity
NOVA_ASSISTANT_NAME=NOVA

# Logging Settings
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
NOVA_LOG_LEVEL=INFO

# Memory Settings
NOVA_MEMORY_ENABLED=true
NOVA_MEMORY_MAX_RECENT=10

# AI/LLM Settings (Phase 5)
NOVA_LLM_ENABLED=false
NOVA_LLM_TIMEOUT=20
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# Screen Awareness / OCR Settings (Phase 6)
NOVA_SCREEN_AWARENESS_ENABLED=true
NOVA_OCR_ENABLED=true
NOVA_OCR_LANGUAGE=eng
# Example Windows Tesseract path:
# NOVA_TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
NOVA_TESSERACT_CMD=

# Safe Automation Settings (Phase 7)
NOVA_AUTOMATION_ENABLED=true
NOVA_REQUIRE_CONFIRMATION_FOR_ACTIONS=true
NOVA_SYSTEM_MONITORING_ENABLED=true

# Feature Directories (Leave blank for defaults)
# Default is project root or standard system folders
NOVA_MUSIC_DIR=
NOVA_NOTES_DIR=
NOVA_SCREENSHOT_DIR=
