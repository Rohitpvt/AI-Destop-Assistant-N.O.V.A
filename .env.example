# NOVA Environment Configuration

# Assistant Identity
NOVA_ASSISTANT_NAME=NOVA

# Logging Settings
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
NOVA_LOG_LEVEL=INFO

# Memory Settings
NOVA_MEMORY_ENABLED=true
NOVA_MEMORY_MAX_RECENT=10

# AI/LLM Settings (Phase 5)
NOVA_LLM_ENABLED=false
NOVA_LLM_TIMEOUT=20
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# Screen Awareness / OCR Settings (Phase 6)
NOVA_SCREEN_AWARENESS_ENABLED=true
NOVA_OCR_ENABLED=true
NOVA_OCR_LANGUAGE=eng
# Example Windows Tesseract path:
# NOVA_TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
NOVA_TESSERACT_CMD=

# Safe Automation Settings (Phase 7)
NOVA_AUTOMATION_ENABLED=true
NOVA_REQUIRE_CONFIRMATION_FOR_ACTIONS=true
NOVA_SYSTEM_MONITORING_ENABLED=true

# Skill System Settings (Phase 8)
NOVA_SKILLS_ENABLED=true
NOVA_SKILL_CONFIRMATION_REQUIRED=true
NOVA_MAX_SKILL_STEPS=5
NOVA_SAVE_SKILL_OUTPUTS=true

# Voice Wake Mode Settings (Phase 9)
NOVA_WAKE_MODE_ENABLED=false
NOVA_WAKE_WORDS=nova,hey nova,wake up nova
NOVA_SLEEP_WORDS=sleep,go to sleep,stop listening
NOVA_EXIT_WORDS=exit,quit,shutdown nova
NOVA_LISTEN_TIMEOUT_SECONDS=5
NOVA_PHRASE_TIME_LIMIT_SECONDS=10
NOVA_VOICE_CONFIRMATION_ENABLED=true
NOVA_VOICE_OUTPUT_ENABLED=true

# GUI Settings (Phase 10)
NOVA_GUI_ENABLED=true
NOVA_GUI_THEME=dark
NOVA_GUI_WINDOW_TITLE=NOVA Desktop Assistant
NOVA_GUI_WIDTH=1000
NOVA_GUI_HEIGHT=700

# Microphone / Speech Recognition Settings
NOVA_MIC_DEVICE_INDEX=
NOVA_MIC_ENERGY_THRESHOLD=300
NOVA_MIC_DYNAMIC_ENERGY_THRESHOLD=true
NOVA_MIC_PAUSE_THRESHOLD=0.8
NOVA_MIC_LISTEN_TIMEOUT_SECONDS=8
NOVA_MIC_PHRASE_TIME_LIMIT_SECONDS=12
NOVA_MIC_AMBIENT_NOISE_DURATION=1.0

# Feature Directories (Leave blank for defaults)
# Default is project root or standard system folders
NOVA_MUSIC_DIR=
NOVA_NOTES_DIR=
NOVA_SCREENSHOT_DIR=
